<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
<title>Balloon Blitz TD</title>
<style>
* { margin:0; padding:0; box-sizing:border-box; -webkit-tap-highlight-color:transparent; }
body { background:#1a1a2e; font-family:system-ui,sans-serif; display:flex; flex-direction:column; align-items:center; height:100vh; overflow:hidden; user-select:none; }
#hdr { width:100%; max-width:480px; display:flex; justify-content:space-between; align-items:center; padding:7px 12px; background:#16213e; border-bottom:2px solid #0f3460; }
.stat { font-size:14px; font-weight:800; color:#fff; display:flex; align-items:center; gap:4px; }
#canvas-container { position:relative; width:100%; max-width:480px; }
canvas { display:block; width:100%; touch-action:none; cursor:crosshair; }
#panel { width:100%; max-width:480px; background:#16213e; padding:7px; border-top:2px solid #0f3460; }
#shop { display:flex; gap:6px; justify-content:center; flex-wrap:wrap; margin-bottom:6px; }
.tbtn { display:flex; flex-direction:column; align-items:center; gap:2px; padding:7px 9px; border-radius:10px; border:2px solid transparent; background:#0f3460; color:#fff; font-weight:700; font-size:10px; cursor:pointer; min-width:65px; transition:.15s; }
.tbtn:active { transform:scale(.95); }
.tbtn.sel { border-color:#f5c842; background:#1a4a80; box-shadow:0 0 10px rgba(245,200,66,.4); }
.tbtn .ti { font-size:20px; }
.tbtn .tc { color:#f5c842; font-size:11px; }
.tbtn.cant { opacity:.4; }
#ctrls { display:flex; gap:6px; justify-content:center; margin-top:5px; flex-wrap:wrap; }
.cbtn { padding:8px 14px; border-radius:9px; border:none; font-weight:800; font-size:12px; cursor:pointer; transition:.15s; }
.cbtn:active { transform:scale(.95); }
#startbtn { background:#22c55e; color:#fff; }
#startbtn.on { background:#f59e0b; }
#sellbtn { background:#e84545; color:#fff; display:none; }
#upgbtn { background:#4facfe; color:#fff; display:none; }
#spdbtn { background:#7c3aed; color:#fff; }
#msg { text-align:center; padding:4px; font-size:11px; color:#94a3b8; font-weight:600; min-height:22px; }
#info { display:none; background:#0f3460; border-radius:9px; padding:7px 11px; margin-top:5px; font-size:11px; color:#e2e8f0; }
#info h3 { color:#f5c842; font-size:12px; margin-bottom:2px; }
.overlay { display:none; position:absolute; inset:0; background:rgba(0,0,0,.83); align-items:center; justify-content:center; flex-direction:column; gap:12px; z-index:50; text-align:center; }
.overlay h2 { font-size:28px; font-weight:900; }
.overlay p { color:#fff; font-size:13px; }
.obtn { padding:11px 26px; border-radius:10px; border:none; background:#f5c842; color:#1a1a2e; font-size:15px; font-weight:900; cursor:pointer; }
</style>
</head>
<body>
<div id="hdr">
  <div class="stat" style="color:#f5c842">💰 <span id="mdisp">150</span></div>
  <div style="font-size:14px;font-weight:900;color:#f5c842;">🎈 Balloon Blitz TD</div>
  <div class="stat" style="color:#ff6b6b">❤️ <span id="ldisp">20</span></div>
</div>
<div id="canvas-container">
  <canvas id="gc"></canvas>
  <div class="overlay" id="goover">
    <h2 style="color:#e84545">💥 Game Over!</h2>
    <p id="gotext">Survived to wave 1</p>
    <button class="obtn" onclick="restart()">Play Again</button>
  </div>
  <div class="overlay" id="winover">
    <h2 style="color:#f5c842">🎉 You Win!</h2>
    <p>All 10 waves defeated!</p>
    <button class="obtn" onclick="restart()">Play Again</button>
  </div>
</div>
<div id="panel">
  <div id="shop">
    <button class="tbtn" id="bd" onclick="selT('dart')"><span class="ti">🎯</span>Dart<span class="tc">💰80</span></button>
    <button class="tbtn" id="bc" onclick="selT('cannon')"><span class="ti">💣</span>Cannon<span class="tc">💰200</span></button>
    <button class="tbtn" id="bf" onclick="selT('freeze')"><span class="ti">❄️</span>Ice<span class="tc">💰150</span></button>
    <button class="tbtn" id="bs" onclick="selT('sniper')"><span class="ti">🔭</span>Sniper<span class="tc">💰300</span></button>
  </div>
  <div id="msg">Select a tower then tap the green area to place it!</div>
  <div id="ctrls">
    <button class="cbtn" id="startbtn" onclick="startWave()">▶ Start Wave</button>
    <button class="cbtn" id="spdbtn" onclick="toggleSpd()">⚡ 1x</button>
    <button class="cbtn" id="sellbtn" onclick="sellSel()">💸 Sell</button>
    <button class="cbtn" id="upgbtn" onclick="upgSel()">⬆ Upgrade</button>
  </div>
  <div id="info"></div>
</div>
<script>
const cv=document.getElementById('gc'),cx=cv.getContext('2d');
let PP=[];
function buildPath(){const W=cv.width,H=cv.height;PP=[{x:0,y:H*.15},{x:W*.26,y:H*.15},{x:W*.26,y:H*.46},{x:W*.63,y:H*.46},{x:W*.63,y:H*.18},{x:W*.88,y:H*.18},{x:W*.88,y:H*.76},{x:W*.38,y:H*.76},{x:W*.38,y:H*.59},{x:W*.12,y:H*.59},{x:W*.12,y:H*1.05}];}
function doResize(){const w=Math.min(document.getElementById('canvas-container').clientWidth,480);cv.width=w;cv.height=Math.round(w*.8);buildPath();}
let $m=150,$l=20,$w=0,$s=1,running=false,over=false,won=false,cleared=false;
let towers=[],bloons=[],projs=[],parts=[],selType=null,selTow=null,spawnQ=[],spawnT=0,prevPos=null,prevOk=false,bid=0,pid=0;
const TD={dart:{cost:80,range:90,dmg:1,rate:1.4,col:'#4facfe',em:'🎯',name:'Dart',uc:75,desc:'Fast shots'},cannon:{cost:200,range:78,dmg:3,rate:.5,col:'#f97316',em:'💣',name:'Cannon',uc:140,desc:'Splash dmg'},freeze:{cost:150,range:82,dmg:0,rate:.6,col:'#67e8f9',em:'❄️',name:'Ice',uc:110,desc:'Slows bloons'},sniper:{cost:300,range:200,dmg:5,rate:.38,col:'#c084fc',em:'🔭',name:'Sniper',uc:180,desc:'Long range'}};
const BT=[{col:'#ef4444',hp:1,spd:1.2,rew:1,sz:14},{col:'#3b82f6',hp:2,spd:1.1,rew:2,sz:15},{col:'#22c55e',hp:3,spd:1,rew:3,sz:16},{col:'#f59e0b',hp:5,spd:.9,rew:5,sz:17},{col:'#a855f7',hp:8,spd:.85,rew:8,sz:17},{col:'#ec4899',hp:14,spd:.8,rew:12,sz:19},{col:'#06b6d4',hp:25,spd:.75,rew:18,sz:21},{col:'#f43f5e',hp:45,spd:.68,rew:25,sz:22},{col:'#334155',hp:90,spd:.62,rew:40,sz:24},{col:'#fbbf24',hp:180,spd:.56,rew:80,sz:29,moab:true}];
const TWAVES=10;
function genWave(w){const q=[],mx=Math.min(w-1,BT.length-1),n=10+w*5;for(let i=0;i<n;i++)q.push(Math.min(Math.floor(Math.random()*(mx+1)),mx));return q;}
function pathLen(){let t=0;for(let i=1;i<PP.length;i++){const dx=PP[i].x-PP[i-1].x,dy=PP[i].y-PP[i-1].y;t+=Math.hypot(dx,dy);}return t;}
function pathPos(d){let r=d;for(let i=1;i<PP.length;i++){const dx=PP[i].x-PP[i-1].x,dy=PP[i].y-PP[i-1].y,s=Math.hypot(dx,dy);if(r<=s){const t=r/s;return{x:PP[i-1].x+dx*t,y:PP[i-1].y+dy*t};}r-=s;}return PP[PP.length-1];}
function onPath(x,y){const M=26;for(let i=1;i<PP.length;i++){const ax=PP[i-1].x,ay=PP[i-1].y,bx=PP[i].x,by=PP[i].y,dx=bx-ax,dy=by-ay,len=dx*dx+dy*dy,t=Math.max(0,Math.min(1,((x-ax)*dx+(y-ay)*dy)/len));if(Math.hypot(x-ax-t*dx,y-ay-t*dy)<M)return true;}return false;}
function towOvlp(x,y){for(const t of towers)if(Math.hypot(t.x-x,t.y-y)<35)return true;return false;}
function spawnB(ti){const d=BT[ti];bloons.push({id:bid++,ti,dist:-30,hp:d.hp,mhp:d.hp,spd:d.spd*(.9+Math.random()*.2),x:PP[0].x,y:PP[0].y,col:d.col,sz:d.sz,frz:0,rew:d.rew,moab:!!d.moab,dead:false});}
function spawnP(t,tgt){const d=TD[t.type];projs.push({id:pid++,x:t.x,y:t.y,tx:tgt.x,ty:tgt.y,tid:tgt.id,spd:6.5,type:t.type,dmg:d.dmg*(1+t.up*.5),col:d.col,spl:t.type==='cannon'?28+t.up*10:0,frz:t.type==='freeze',famt:1.8+t.up*.5,done:false});}
function splParts(x,y,col,n=6){for(let i=0;i<n;i++){const a=Math.random()*Math.PI*2,s=1.5+Math.random()*3;parts.push({x,y,vx:Math.cos(a)*s,vy:Math.sin(a)*s-1,col,life:1,sz:3+Math.random()*4});}}
function hitB(b,p){if(p.frz){b.frz=Math.max(b.frz,p.famt);}else{b.hp-=p.dmg;if(b.hp<=0){$m+=b.rew;document.getElementById('mdisp').textContent=$m;splParts(b.x,b.y,b.col,b.moab?20:7);updShop();}}}
function lighten(h){const r=parseInt(h.slice(1,3),16),g=parseInt(h.slice(3,5),16),b=parseInt(h.slice(5,7),16);return `rgb(${Math.min(255,r+55)},${Math.min(255,g+55)},${Math.min(255,b+55)})`;}
function update(dt){
  if(over||won)return;const sm=$s;
  if(running){spawnT-=dt*sm;if(spawnT<=0&&spawnQ.length>0){spawnB(spawnQ.shift());spawnT=.45+Math.random()*.3;}}
  const pl=pathLen();
  for(const b of bloons){if(b.dead)continue;let s=b.spd;if(b.frz>0){b.frz-=dt*sm;s*=.12;}b.dist+=s*55*dt*sm;if(b.dist>=pl){b.dead=true;$l=Math.max(0,$l-1);splParts(b.x,b.y,b.col,3);document.getElementById('ldisp').textContent=$l;if($l<=0&&!over)endGame(false);}else{const p=pathPos(b.dist);b.x=p.x;b.y=p.y;}}
  bloons=bloons.filter(b=>!b.dead&&b.hp>0);
  const now=performance.now()/1000;
  for(const t of towers){if(!t.lf)t.lf=0;const d=TD[t.type],iv=(1/(d.rate*(1+t.up*.2)))/sm;if(now-t.lf>=iv){const rng=d.range*(1+t.up*.15);let best=null,bd=-1;for(const b of bloons){if(Math.hypot(b.x-t.x,b.y-t.y)<=rng&&b.dist>bd){bd=b.dist;best=b;}}if(best){spawnP(t,best);t.lf=now;}}}
  for(const p of projs){const tgt=bloons.find(b=>b.id===p.tid);if(tgt){p.tx=tgt.x;p.ty=tgt.y;}const dx=p.tx-p.x,dy=p.ty-p.y,d=Math.hypot(dx,dy);if(d<p.spd*sm*2){p.done=true;splParts(p.tx,p.ty,p.col,p.spl?8:3);if(p.spl>0){for(const b of bloons)if(Math.hypot(b.x-p.tx,b.y-p.ty)<=p.spl)hitB(b,p);}else if(tgt)hitB(tgt,p);}else{p.x+=dx/d*p.spd*sm;p.y+=dy/d*p.spd*sm;}}
  projs=projs.filter(p=>!p.done);
  for(const p of parts){p.x+=p.vx*sm;p.y+=p.vy*sm;p.vy+=.12*sm;p.life-=.03*sm;}
  parts=parts.filter(p=>p.life>0);
  if(running&&spawnQ.length===0&&bloons.length===0&&!cleared){cleared=true;running=false;const bon=50+$w*10;$m+=bon;document.getElementById('mdisp').textContent=$m;setMsg(`🎉 Wave ${$w} cleared! +$${bon} bonus!`);const sb=document.getElementById('startbtn');sb.textContent=$w>=TWAVES?'🏆 Complete!':'▶ Next Wave';sb.classList.remove('on');updShop();if($w>=TWAVES)endGame(true);}
}
function endGame(w){if(w){won=true;document.getElementById('winover').style.display='flex';}else{over=true;document.getElementById('gotext').textContent=`Survived to wave ${$w}`;document.getElementById('goover').style.display='flex';}}
function draw(){
  const W=cv.width,H=cv.height;cx.clearRect(0,0,W,H);cx.fillStyle='#2d7a2d';cx.fillRect(0,0,W,H);
  cx.strokeStyle='rgba(0,0,0,.05)';cx.lineWidth=1;for(let x=0;x<W;x+=22){cx.beginPath();cx.moveTo(x,0);cx.lineTo(x,H);cx.stroke();}for(let y=0;y<H;y+=22){cx.beginPath();cx.moveTo(0,y);cx.lineTo(W,y);cx.stroke();}
  cx.lineCap='round';cx.lineJoin='round';
  cx.strokeStyle='rgba(0,0,0,.2)';cx.lineWidth=42;cx.beginPath();cx.moveTo(PP[0].x,PP[0].y);for(let i=1;i<PP.length;i++)cx.lineTo(PP[i].x,PP[i].y);cx.stroke();
  cx.strokeStyle='#c8a96e';cx.lineWidth=36;cx.stroke();cx.strokeStyle='#d4b87e';cx.lineWidth=28;cx.stroke();
  cx.strokeStyle='#a08050';cx.lineWidth=40;cx.globalAlpha=.3;cx.stroke();cx.globalAlpha=1;
  cx.fillStyle='#22c55e';cx.beginPath();cx.arc(PP[0].x,PP[0].y,8,0,Math.PI*2);cx.fill();
  const lp=PP[PP.length-1];cx.fillStyle='#ef4444';cx.beginPath();cx.arc(lp.x,lp.y,8,0,Math.PI*2);cx.fill();
  cx.fillStyle='#fff';cx.font='bold 8px sans-serif';cx.textAlign='center';cx.textBaseline='middle';cx.fillText('IN',PP[0].x,PP[0].y);cx.fillText('OUT',lp.x,lp.y);
  if(selTow){const d=TD[selTow.type],rng=d.range*(1+selTow.up*.15);cx.strokeStyle='rgba(255,255,255,.22)';cx.lineWidth=1.5;cx.setLineDash([5,5]);cx.beginPath();cx.arc(selTow.x,selTow.y,rng,0,Math.PI*2);cx.stroke();cx.setLineDash([]);}
  for(const t of towers){const d=TD[t.type],sel=t===selTow;cx.fillStyle=sel?'#2a5a9f':'#1e3a5f';cx.beginPath();cx.arc(t.x,t.y,16,0,Math.PI*2);cx.fill();cx.strokeStyle=d.col;cx.lineWidth=sel?3:2;cx.beginPath();cx.arc(t.x,t.y,16,0,Math.PI*2);cx.stroke();if(sel){cx.strokeStyle='rgba(255,220,0,.55)';cx.lineWidth=4;cx.globalAlpha=.5;cx.beginPath();cx.arc(t.x,t.y,19,0,Math.PI*2);cx.stroke();cx.globalAlpha=1;}for(let u=0;u<t.up;u++){const a=(u/3)*Math.PI*2-Math.PI/2;cx.fillStyle='#fbbf24';cx.beginPath();cx.arc(t.x+Math.cos(a)*12,t.y+Math.sin(a)*12,2.5,0,Math.PI*2);cx.fill();}cx.font='14px serif';cx.textAlign='center';cx.textBaseline='middle';cx.fillText(d.em,t.x,t.y);}
  for(const b of bloons){const fz=b.frz>0;cx.fillStyle='rgba(0,0,0,.13)';cx.beginPath();cx.ellipse(b.x,b.y+b.sz+2,b.sz*.6,3,0,0,Math.PI*2);cx.fill();const g=cx.createRadialGradient(b.x-b.sz*.3,b.y-b.sz*.3,1,b.x,b.y,b.sz);g.addColorStop(0,fz?'#a5f3fc':lighten(b.col));g.addColorStop(1,fz?'#0891b2':b.col);cx.fillStyle=g;cx.beginPath();cx.arc(b.x,b.y,b.sz,0,Math.PI*2);cx.fill();cx.fillStyle='rgba(255,255,255,.3)';cx.beginPath();cx.ellipse(b.x-b.sz*.27,b.y-b.sz*.28,b.sz*.28,b.sz*.19,-.4,0,Math.PI*2);cx.fill();cx.strokeStyle='#555';cx.lineWidth=1;cx.beginPath();cx.moveTo(b.x,b.y+b.sz);cx.lineTo(b.x,b.y+b.sz+7);cx.stroke();if(b.hp<b.mhp){const bw=b.sz*2,bx=b.x-bw/2,by=b.y-b.sz-6;cx.fillStyle='#ef4444';cx.fillRect(bx,by,bw,3);cx.fillStyle='#22c55e';cx.fillRect(bx,by,bw*(b.hp/b.mhp),3);}if(b.moab){cx.fillStyle='#fff';cx.font='bold 7px sans-serif';cx.textAlign='center';cx.textBaseline='middle';cx.fillText('MOAB',b.x,b.y);}}
  for(const p of projs){cx.fillStyle=p.col;cx.beginPath();cx.arc(p.x,p.y,p.type==='cannon'?6.5:4,0,Math.PI*2);cx.fill();if(p.spl>0){cx.strokeStyle=p.col;cx.lineWidth=1;cx.globalAlpha=.2;cx.beginPath();cx.arc(p.x,p.y,p.spl,0,Math.PI*2);cx.stroke();cx.globalAlpha=1;}}
  for(const p of parts){cx.globalAlpha=p.life;cx.fillStyle=p.col;cx.beginPath();cx.arc(p.x,p.y,p.sz*p.life,0,Math.PI*2);cx.fill();}
  cx.globalAlpha=1;
  if(prevPos&&selType){const d=TD[selType];cx.globalAlpha=.58;cx.fillStyle=prevOk?d.col:'#ef4444';cx.beginPath();cx.arc(prevPos.x,prevPos.y,16,0,Math.PI*2);cx.fill();cx.globalAlpha=.13;cx.fillStyle=prevOk?d.col:'#ef4444';cx.beginPath();cx.arc(prevPos.x,prevPos.y,d.range,0,Math.PI*2);cx.fill();cx.globalAlpha=1;cx.font='14px serif';cx.textAlign='center';cx.textBaseline='middle';cx.fillText(d.em,prevPos.x,prevPos.y);}
}
function getXY(cX,cY){const r=cv.getBoundingClientRect();return{x:(cX-r.left)*(cv.width/r.width),y:(cY-r.top)*(cv.height/r.height)};}
function updPrev(x,y){prevPos={x,y};prevOk=!onPath(x,y)&&!towOvlp(x,y)&&x>10&&y>10&&x<cv.width-10&&y<cv.height-10;}
cv.addEventListener('mousemove',e=>{if(selType){const p=getXY(e.clientX,e.clientY);updPrev(p.x,p.y);}});
cv.addEventListener('mouseleave',()=>{prevPos=null;});
cv.addEventListener('touchmove',e=>{e.preventDefault();if(selType){const t=e.touches[0],p=getXY(t.clientX,t.clientY);updPrev(p.x,p.y);}},{passive:false});
cv.addEventListener('touchend',e=>{e.preventDefault();const t=e.changedTouches[0],p=getXY(t.clientX,t.clientY);tap(p.x,p.y);},{passive:false});
cv.addEventListener('click',e=>{const p=getXY(e.clientX,e.clientY);tap(p.x,p.y);});
function tap(x,y){
  if(selType){const d=TD[selType];if($m<d.cost){setMsg('❌ Not enough money!');return;}if(onPath(x,y)){setMsg('❌ Cannot place on path!');return;}if(towOvlp(x,y)){setMsg('❌ Too close to another tower!');return;}if(x<10||y<10||x>cv.width-10||y>cv.height-10){setMsg('❌ Too close to edge!');return;}$m-=d.cost;document.getElementById('mdisp').textContent=$m;towers.push({x,y,type:selType,up:0,lf:0});prevPos=null;updShop();setMsg(`✅ ${d.name} placed!`);}
  else{let hit=null;for(const t of towers)if(Math.hypot(t.x-x,t.y-y)<21){hit=t;break;}if(hit){selTow=hit;showInfo(hit);}else{selTow=null;document.getElementById('info').style.display='none';document.getElementById('sellbtn').style.display='none';document.getElementById('upgbtn').style.display='none';}}
}
function showInfo(t){const d=TD[t.type],el=document.getElementById('info');el.style.display='block';el.innerHTML=`<h3>${d.em} ${d.name} — Lv${t.up+1}</h3><div>${d.desc} | Rng:${Math.round(d.range*(1+t.up*.15))} Dmg:${(d.dmg*(1+t.up*.5)).toFixed(1)} Rate:${(d.rate*(1+t.up*.2)).toFixed(1)}/s</div>${t.up<3?`<div style="color:#f5c842;margin-top:2px">Upgrade: 💰${d.uc}</div>`:'<div style="color:#22c55e;margin-top:2px">✨ Max Level</div>'}`;document.getElementById('sellbtn').style.display='inline-block';document.getElementById('upgbtn').style.display=t.up<3?'inline-block':'none';}
function sellSel(){if(!selTow)return;const d=TD[selTow.type],r=Math.floor(d.cost*.6+d.uc*selTow.up*.5);$m+=r;document.getElementById('mdisp').textContent=$m;towers=towers.filter(t=>t!==selTow);selTow=null;document.getElementById('info').style.display='none';document.getElementById('sellbtn').style.display='none';document.getElementById('upgbtn').style.display='none';setMsg(`💸 Sold for $${r}`);updShop();}
function upgSel(){if(!selTow||selTow.up>=3)return;const d=TD[selTow.type];if($m<d.uc){setMsg('❌ Not enough money!');return;}$m-=d.uc;selTow.up++;document.getElementById('mdisp').textContent=$m;updShop();showInfo(selTow);splParts(selTow.x,selTow.y,'#fbbf24',10);setMsg(`⬆ Upgraded to Level ${selTow.up+1}!`);}
function selT(type){const d=TD[type];if($m<d.cost){setMsg(`❌ Need 💰${d.cost} for ${d.name}`);return;}selType=type;selTow=null;document.getElementById('info').style.display='none';document.getElementById('sellbtn').style.display='none';document.getElementById('upgbtn').style.display='none';document.querySelectorAll('.tbtn').forEach(b=>b.classList.remove('sel'));const ids={dart:'bd',cannon:'bc',freeze:'bf',sniper:'bs'};document.getElementById(ids[type]).classList.add('sel');setMsg(`📍 Tap the grass to place ${d.em} ${d.name}!`);}
function updShop(){const ids={dart:'bd',cannon:'bc',freeze:'bf',sniper:'bs'};for(const[k,d]of Object.entries(TD)){const b=document.getElementById(ids[k]);if(b)b.classList.toggle('cant',$m<d.cost);}}
function setMsg(m){document.getElementById('msg').textContent=m;}
function startWave(){if(over||won||running)return;if($w>=TWAVES)return;$w++;cleared=false;selType=null;document.querySelectorAll('.tbtn').forEach(b=>b.classList.remove('sel'));document.getElementById('info').style.display='none';document.getElementById('sellbtn').style.display='none';document.getElementById('upgbtn').style.display='none';spawnQ=genWave($w);spawnT=0;running=true;const sb=document.getElementById('startbtn');sb.textContent=`🌊 Wave ${$w}/${TWAVES}`;sb.classList.add('on');setMsg(`🌊 Wave ${$w} incoming!`);}
function toggleSpd(){$s=$s===1?2:$s===2?3:1;document.getElementById('spdbtn').textContent=`⚡ ${$s}x`;}
function restart(){$m=150;$l=20;$w=0;$s=1;running=false;over=false;won=false;cleared=false;towers=[];bloons=[];projs=[];parts=[];selType=null;selTow=null;spawnQ=[];spawnT=0;prevPos=null;document.getElementById('mdisp').textContent=$m;document.getElementById('ldisp').textContent=$l;document.getElementById('startbtn').textContent='▶ Start Wave';document.getElementById('startbtn').classList.remove('on');document.getElementById('spdbtn').textContent='⚡ 1x';document.getElementById('goover').style.display='none';document.getElementById('winover').style.display='none';document.getElementById('info').style.display='none';document.getElementById('sellbtn').style.display='none';document.getElementById('upgbtn').style.display='none';document.querySelectorAll('.tbtn').forEach(b=>b.classList.remove('sel'));setMsg('Select a tower then tap the green area to place it!');updShop();}
let lt=0;
function loop(ts){const dt=Math.min((ts-lt)/1000,.05);lt=ts;update(dt);draw();requestAnimationFrame(loop);}
window.addEventListener('resize',doResize);
doResize();updShop();lt=performance.now();requestAnimationFrame(loop);
</script>
</body>
</html>
